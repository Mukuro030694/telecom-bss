{% extends 'base.html.twig' %}
{% from '_macros.html.twig' import statusBadge, emptyState %}

{% block title %}Клиенты{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Клиенты</h1>
    <a href="{{ path('customer_create') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Новый клиент
    </a>
</div>

{# Поиск #}
<form method="get" class="mb-4">
    <div class="input-group" style="max-width: 400px">
        <input type="text"
               name="q"
               class="form-control"
               placeholder="Поиск по имени или email..."
               value="{{ query }}">
        <button class="btn btn-outline-secondary" type="submit">
            <i class="bi bi-search"></i>
        </button>
        {% if query %}
            <a href="{{ path('customer_index') }}" class="btn btn-outline-danger">
                <i class="bi bi-x"></i>
            </a>
        {% endif %}
    </div>
</form>

{% if customers is empty %}
    {{ emptyState('Клиенты не найдены', 'people') }}
{% else %}
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Клиент</th>
                        <th>Email</th>
                        <th>Телефон</th>
                        <th>Тарифы</th>
                        <th>Статус</th>
                        <th>Дата регистрации</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for customer in customers %}
                        <tr>
                            <td class="fw-semibold">{{ customer.fullName }}</td>
                            <td class="text-muted">{{ customer.email }}</td>
                            <td class="text-muted">{{ customer.phone ?? '—' }}</td>
                            <td>
                                {% set activeSubscriptions = customer.subscriptions|filter(s => s.isActive) %}
                                {% if activeSubscriptions is empty %}
                                    <span class="text-muted">—</span>
                                {% else %}
                                    {% for sub in activeSubscriptions %}
                                        <span class="badge bg-secondary me-1">
                                            {{ sub.tariffPlan.name }}
                                        </span>
                                    {% endfor %}
                                {% endif %}
                            </td>
                            <td>{{ statusBadge(customer.status) }}</td>
                            <td class="text-muted small">
                                {{ customer.createdAt|date('d.m.Y') }}
                            </td>
                            <td>
                                <a href="{{ path('customer_show', {id: customer.id}) }}"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <div class="text-muted small mt-2">Всего: {{ customers|length }}</div>
{% endif %}
{% endblock %}