{% extends 'base.html.twig' %}
{% from '_macros.html.twig' import breadcrumbs %}

{% block title %}Новый клиент{% endblock %}

{% block body %}
{{ breadcrumbs([
    {label: 'Клиенты', url: path('customer_index')},
    {label: 'Новый клиент'}
]) }}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h5 mb-4">Новый клиент</h2>
                <form method="post" action="{{ path('customer_create') }}">
                    {% include 'customer/_form.html.twig' %}
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Создать
                        </button>
                        <a href="{{ path('customer_index') }}"
                           class="btn btn-outline-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}